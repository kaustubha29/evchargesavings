# Supabase — get these from: supabase.com → project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJh...   # service_role key (NOT the anon key — keep this secret)

# Resend — get from: resend.com → API Keys
RESEND_API_KEY=re_...

# EIA — get free key from: eia.gov/opendata/
# Powers live state gas prices + electricity rates (falls back to static if unset)
EIA_API_KEY=
